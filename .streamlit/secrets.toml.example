# ============================================================
# .streamlit/secrets.toml.example
#
# 1. Copy this file: cp .streamlit/secrets.toml.example .streamlit/secrets.toml
# 2. Fill in real values
# 3. NEVER commit secrets.toml to git (it is in .gitignore)
# ============================================================

# Required: Anthropic API key
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY = "sk-ant-..."

# Required: Demo access code shared with C-suite attendees
ACCESS_CODE = "hitron2025"

# Optional: Voyage AI embeddings (higher quality than MiniLM)
# Requires re-running ingest.py with USE_VOYAGE_EMBEDDINGS=True in config.py
# Get from: https://dash.voyageai.com/
# VOYAGE_API_KEY = "pa-..."
